        <Param val="from exp settings" valType="str" updates="None" name="units"/>
        <Param val="" valType="code" updates="None" name="validator"/>
      </ImageComponent>
      <CodeComponent name="Tobii_SDK_disconnect" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="my_eyetracker.unsubscribe_from(tr.EYETRACKER_GAZE_DATA, gaze_callback)&amp;#10;print('ET stopped')" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="my_eyetracker.unsubscribe_from(tr.EYETRACKER_GAZE_DATA, gaze_callback);&amp;#10;console.log(&quot;ET stopped&quot;);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="Tobii_SDK_disconnect" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
  </Routines>
  <Flow>
    <Routine name="Start_ET"/>
    <LoopInitiator loopType="TrialHandler" name="trialLoop">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[{'image_fam': 'fractals/fractal_complex_pair1_a_bright.png', 'image_left': 'fractals/fractal_complex_pair1_a_bright.png', 'image_right': 'fractals/fractal_complex_pair1_b_bright.png', 'fam_IC_time': 5, 'fam_max_time': 10}, {'image_fam': 'fractals/fractal_simple_pair1_a_bright.png', 'image_left': 'fractals/fractal_simple_pair1_b_bright.png', 'image_right': 'fractals/fractal_simple_pair1_a_bright.png', 'fam_IC_time': 10, 'fam_max_time': 20}, {'image_fam': 'fractals/fractal_complex_pair2_a_bright.png', 'image_left': 'fractals/fractal_complex_pair2_a_bright.png', 'image_right': 'fractals/fractal_complex_pair2_b_bright.png', 'fam_IC_time': 15, 'fam_max_time': 30}, {'image_fam': 'fractals/fractal_simple_pair2_a_bright.png', 'image_left': 'fractals/fractal_simple_pair2_b_bright.png', 'image_right': 'fractals/fractal_simple_pair2_a_bright.png', 'fam_IC_time': 5, 'fam_max_time': 10}, {'image_fam': 'fractals/fractal_complex_pair3_a_bright.png', 'image_left': 'fractals/fractal_complex_pair3_a_bright.png', 'image_right': 'fractals/fractal_complex_pair3_b_bright.png', 'fam_IC_time': 10, 'fam_max_time': 20}, {'image_fam': 'fractals/fractal_simple_pair3_a_bright.png', 'image_left': 'fractals/fractal_simple_pair3_b_bright.png', 'image_right': 'fractals/fractal_simple_pair3_a_bright.png', 'fam_IC_time': 15, 'fam_max_time': 30}, {'image_fam': 'fribbles/Arrow_Complex.png', 'image_left': 'fribbles/Arrow_Complex.png', 'image_right': 'fribbles/Bowl_Complex.png', 'fam_IC_time': 5, 'fam_max_time': 10}, {'image_fam': 'fribbles/Bowtie_Simple.png', 'image_left': 'fribbles/Crinkle_Simple.png', 'image_right': 'fribbles/Bowtie_Simple.png', 'fam_IC_time': 10, 'fam_max_time': 20}, {'image_fam': 'fribbles/Cylinder_Complex.png', 'image_left': 'fribbles/Cylinder_Complex.png', 'image_right': 'fribbles/Diamond_Complex.png', 'fam_IC_time': 15, 'fam_max_time': 30}, {'image_fam': 'fribbles/Gumdrop_Simple.png', 'image_left': 'fribbles/Pacman_Simple.png', 'image_right': 'fribbles/Gumdrop_Simple.png', 'fam_IC_time': 5, 'fam_max_time': 10}, {'image_fam': 'fribbles/Pumpkin_Complex.png', 'image_left': 'fribbles/Pumpkin_Complex.png', 'image_right': 'fribbles/Pyramid_Complex.png', 'fam_IC_time': 10, 'fam_max_time': 20}, {'image_fam': 'fribbles/SimsDiamond_Simple.png', 'image_left': 'fribbles/Tripod_Simple.png', 'image_right': 'fribbles/SimsDiamond_Simple.png', 'fam_IC_time': 15, 'fam_max_time': 30}]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="preferential looking paradigm.xlsx" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="num"/>
      <Param name="name" updates="None" val="trialLoop" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="Laughing_Baby"/>
    <Routine name="Familiarization"/>
    <LoopInitiator loopType="TrialHandler" name="testLoop">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="None" valType="str"/>
      <Param name="conditionsFile" updates="None" val="" valType="file"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="False" valType="bool"/>
      <Param name="loopType" updates="None" val="sequential" valType="str"/>
      <Param name="nReps" updates="None" val="2" valType="num"/>
      <Param name="name" updates="None" val="testLoop" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="Central_Fixation"/>
    <Routine name="Test_Period"/>
    <LoopTerminator name="testLoop"/>
    <LoopTerminator name="trialLoop"/>
    <Routine name="Stop_ET"/>
  </Flow>
</PsychoPy2experiment>
