      <CodeComponent name="code_test" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="if ((testLoop.thisN === 0)) {&amp;#10;    imgLeft.image = image_left;&amp;#10;    imgRight.image = image_right;&amp;#10;} else {&amp;#10;    imgLeft.image = image_right;&amp;#10;    imgRight.image = image_left;&amp;#10;}&amp;#10;trialClock = new util.Clock();&amp;#10;roiClockLeft = new util.Clock();&amp;#10;roiClockRight = new util.Clock();&amp;#10;sampleIndex = 0;&amp;#10;gazeTimeLeft = 0;&amp;#10;inROILeft = 0;&amp;#10;gazeInROILeft = false;&amp;#10;gazeTimeRight = 0;&amp;#10;inROIRight = 0;&amp;#10;gazeInROIRight = false;&amp;#10;[x0, y0] = [(ROI_left.pos[0] - (ROI_left.size[0] / 2)), (ROI_left.pos[1] - (ROI_left.size[1] / 2))];&amp;#10;[x1, y1] = [(ROI_left.pos[0] + (ROI_left.size[0] / 2)), (ROI_left.pos[1] + (ROI_left.size[1] / 2))];&amp;#10;[x2, y2] = [(ROI_right.pos[0] - (ROI_right.size[0] / 2)), (ROI_right.pos[1] - (ROI_right.size[1] / 2))];&amp;#10;[x3, y3] = [(ROI_right.pos[0] + (ROI_right.size[0] / 2)), (ROI_right.pos[1] + (ROI_right.size[1] / 2))];&amp;#10;maxTime = 5;&amp;#10;console.log(&quot;Test started&quot;);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="if testLoop.thisN == 0:&amp;#10;    imgLeft.image = image_left&amp;#10;    imgRight.image = image_right&amp;#10;else:&amp;#10;    imgLeft.image = image_right&amp;#10;    imgRight.image = image_left&amp;#10;&amp;#10;# Timer for this trial&amp;#10;trialClock = core.Clock()  # overall max display time&amp;#10;roiClockLeft = core.Clock()    # timer for fixation in ROI&amp;#10;roiClockRight = core.Clock()&amp;#10;&amp;#10;# Gaze tracking&amp;#10;sampleIndex = 0&amp;#10;&amp;#10;gazeTimeLeft = 0 &amp;#10;inROILeft = 0&amp;#10;gazeInROILeft = False&amp;#10;&amp;#10;gazeTimeRight = 0&amp;#10;inROIRight = 0&amp;#10;gazeInROIRight = False&amp;#10;&amp;#10;# Define ROI Left&amp;#10;x0, y0 = ROI_left.pos[0] - ROI_left.size[0]/2, ROI_left.pos[1] - ROI_left.size[1]/2&amp;#10;x1, y1 = ROI_left.pos[0] + ROI_left.size[0]/2, ROI_left.pos[1] + ROI_left.size[1]/2&amp;#10;&amp;#10;# Define ROI Right&amp;#10;x2, y2 = ROI_right.pos[0] - ROI_right.size[0]/2, ROI_right.pos[1] - ROI_right.size[1]/2&amp;#10;x3, y3 = ROI_right.pos[0] + ROI_right.size[0]/2, ROI_right.pos[1] + ROI_right.size[1]/2&amp;#10;&amp;#10;maxTime = 5&amp;#10;&amp;#10;print('Test started')" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="# ---------- ROI TIME ACCUMULATION ----------&amp;#10;#if roi_familiarization.status == STARTED:&amp;#10;&amp;#10;# Current time&amp;#10;currentTime = trialClock.getTime()&amp;#10;# Get current gaze position&amp;#10;gazePos = get_current_gaze()  # (x, y) or None&amp;#10;&amp;#10;if gazePos is not None:&amp;#10;    gazeX, gazeY = gazePos&amp;#10;&amp;#10;    # Left ROI&amp;#10;    if x0 &lt;= gazeX &lt;= x1 and y0 &lt;= gazeY &lt;= y1:&amp;#10;        inROILeft = 1&amp;#10;        if not gazeInROILeft:&amp;#10;            roiClockLeft.reset()&amp;#10;            gazeInROILeft = True&amp;#10;        gazeTimeLeft = roiClockLeft.getTime()&amp;#10;    else:&amp;#10;        inROILeft = 0&amp;#10;        if gazeInROILeft:&amp;#10;            gazeTimeLeft += roiClockLeft.getTime()&amp;#10;            gazeInROILeft = False&amp;#10;&amp;#10;    # Right ROI&amp;#10;    if x2 &lt;= gazeX &lt;= x3 and y2 &lt;= gazeY &lt;= y3:&amp;#10;        inROIRight = 1&amp;#10;        if not gazeInROIRight:&amp;#10;            roiClockRight.reset()&amp;#10;            gazeInROIRight = True&amp;#10;        gazeTimeRight = roiClockRight.getTime()&amp;#10;    else:&amp;#10;        inROIRight = 0&amp;#10;        if gazeInROIRight:&amp;#10;            gazeTimeRight += roiClockRight.getTime()&amp;#10;            gazeInROIRight = False&amp;#10;&amp;#10;# ---------- SAVE RAW GAZE SAMPLE ----------&amp;#10;sampleIndex += 1&amp;#10;thisExp.addData('gaze_sample_index', sampleIndex)&amp;#10;thisExp.addData('trial_time', currentTime)&amp;#10;thisExp.addData('gaze_x', gazeX)&amp;#10;thisExp.addData('gaze_y', gazeY)&amp;#10;thisExp.addData('gaze_in_roi_left', inROILeft)&amp;#10;thisExp.addData('gaze_time_in_roi_left', gazeTimeLeft)&amp;#10;thisExp.addData('gaze_in_roi_right', inROIRight)&amp;#10;thisExp.addData('gaze_time_in_roi_right', gazeTimeRight)&amp;#10;&amp;#10;thisExp.nextEntry()  # VERY IMPORTANT&amp;#10;&amp;#10;if currentTime &gt;= maxTime:&amp;#10;    continueRoutine = False&amp;#10;&amp;#10;# Optional: exit experiment&amp;#10;if 'escape' in event.getKeys():&amp;#10;    core.quit()&amp;#10;" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="var _pj;&amp;#10;function _pj_snippets(container) {&amp;#10;    function in_es6(left, right) {&amp;#10;        if (((right instanceof Array) || ((typeof right) === &quot;string&quot;))) {&amp;#10;            return (right.indexOf(left) &gt; (- 1));&amp;#10;        } else {&amp;#10;            if (((right instanceof Map) || (right instanceof Set) || (right instanceof WeakMap) || (right instanceof WeakSet))) {&amp;#10;                return right.has(left);&amp;#10;            } else {&amp;#10;                return (left in right);&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    container[&quot;in_es6&quot;] = in_es6;&amp;#10;    return container;&amp;#10;}&amp;#10;_pj = {};&amp;#10;_pj_snippets(_pj);&amp;#10;currentTime = trialClock.getTime();&amp;#10;gazePos = get_current_gaze();&amp;#10;if ((gazePos !== null)) {&amp;#10;    [gazeX, gazeY] = gazePos;&amp;#10;    if ((((x0 &lt;= gazeX) &amp;&amp; (gazeX &lt;= x1)) &amp;&amp; ((y0 &lt;= gazeY) &amp;&amp; (gazeY &lt;= y1)))) {&amp;#10;        inROILeft = 1;&amp;#10;        if ((! gazeInROILeft)) {&amp;#10;            roiClockLeft.reset();&amp;#10;            gazeInROILeft = true;&amp;#10;        }&amp;#10;        gazeTimeLeft = roiClockLeft.getTime();&amp;#10;    } else {&amp;#10;        inROILeft = 0;&amp;#10;        if (gazeInROILeft) {&amp;#10;            gazeTimeLeft += roiClockLeft.getTime();&amp;#10;            gazeInROILeft = false;&amp;#10;        }&amp;#10;    }&amp;#10;    if ((((x2 &lt;= gazeX) &amp;&amp; (gazeX &lt;= x3)) &amp;&amp; ((y2 &lt;= gazeY) &amp;&amp; (gazeY &lt;= y3)))) {&amp;#10;        inROIRight = 1;&amp;#10;        if ((! gazeInROIRight)) {&amp;#10;            roiClockRight.reset();&amp;#10;            gazeInROIRight = true;&amp;#10;        }&amp;#10;        gazeTimeRight = roiClockRight.getTime();&amp;#10;    } else {&amp;#10;        inROIRight = 0;&amp;#10;        if (gazeInROIRight) {&amp;#10;            gazeTimeRight += roiClockRight.getTime();&amp;#10;            gazeInROIRight = false;&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;sampleIndex += 1;&amp;#10;psychoJS.experiment.addData(&quot;gaze_sample_index&quot;, sampleIndex);&amp;#10;psychoJS.experiment.addData(&quot;trial_time&quot;, currentTime);&amp;#10;psychoJS.experiment.addData(&quot;gaze_x&quot;, gazeX);&amp;#10;psychoJS.experiment.addData(&quot;gaze_y&quot;, gazeY);&amp;#10;psychoJS.experiment.addData(&quot;gaze_in_roi_left&quot;, inROILeft);&amp;#10;psychoJS.experiment.addData(&quot;gaze_time_in_roi_left&quot;, gazeTimeLeft);&amp;#10;psychoJS.experiment.addData(&quot;gaze_in_roi_right&quot;, inROIRight);&amp;#10;psychoJS.experiment.addData(&quot;gaze_time_in_roi_right&quot;, gazeTimeRight);&amp;#10;psychoJS.experiment.nextEntry();&amp;#10;if ((currentTime &gt;= maxTime)) {&amp;#10;    continueRoutine = false;&amp;#10;}&amp;#10;if (_pj.in_es6(&quot;escape&quot;, psychoJS.eventManager.getKeys())) {&amp;#10;    core.quit();&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="code_test" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
