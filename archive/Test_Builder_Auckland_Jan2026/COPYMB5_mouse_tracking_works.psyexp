      <CodeComponent name="Tobii_SDK_connect" plugin="None">
        <Param val="import tobii_research as tr&amp;#10;from psychopy import visual&amp;#10;&amp;#10;#get screen size in pix&amp;#10;win = visual.Window(fullscr=True)&amp;#10;#win_width, win_height = win.size&amp;#10;#print(win_width, win_height)&amp;#10;&amp;#10;found_eyetrackers = tr.find_all_eyetrackers()&amp;#10;if not found_eyetrackers:&amp;#10;    raise RuntimeError(&quot;No Tobii eye trackers found!&quot;)&amp;#10;&amp;#10;my_eyetracker = found_eyetrackers[0]&amp;#10;print(f&quot;Using eye tracker: {my_eyetracker}&quot;)&amp;#10;&amp;#10;gaze_data = []&amp;#10;&amp;#10;# global dictionary to hold the latest gaze&amp;#10;latest_gaze = {'left_x': None, 'left_y': None, 'right_x': None, 'right_y': None}&amp;#10;&amp;#10;def gaze_callback(gaze_sample):&amp;#10;    # update latest gaze&amp;#10;    latest_gaze['left_x'] = gaze_sample['left_gaze_point_on_display_area'][0]&amp;#10;    latest_gaze['left_y'] = gaze_sample['left_gaze_point_on_display_area'][1]&amp;#10;    latest_gaze['right_x'] = gaze_sample['right_gaze_point_on_display_area'][0]&amp;#10;    latest_gaze['right_y'] = gaze_sample['right_gaze_point_on_display_area'][1]&amp;#10;    &amp;#10;    # optionally still log all samples&amp;#10;    timestamp = time.time()&amp;#10;    gaze_data.append({&amp;#10;        'timestamp': timestamp,&amp;#10;        'left_x': latest_gaze['left_x'],&amp;#10;        'left_y': latest_gaze['left_y'],&amp;#10;        'right_x': latest_gaze['right_x'],&amp;#10;        'right_y': latest_gaze['right_y']&amp;#10;    })&amp;#10;&amp;#10;def get_current_gaze():&amp;#10;    &quot;&quot;&quot;&amp;#10;    Returns the current gaze position as a tuple (x, y),&amp;#10;    averaged between left and right eyes if both are available.&amp;#10;    Falls back to a single eye if the other is missing.&amp;#10;    Returns None if no gaze data is available.&amp;#10;    &quot;&quot;&quot;&amp;#10;    left_x = latest_gaze['left_x']&amp;#10;    left_y = latest_gaze['left_y']&amp;#10;    right_x = latest_gaze['right_x']&amp;#10;    right_y = latest_gaze['right_y']&amp;#10;&amp;#10;    if left_x is not None and right_x is not None:&amp;#10;        # midpoint between eyes&amp;#10;        # Org. Tobii coordinates&amp;#10;        #gaze_x = (left_x + right_x) / 2&amp;#10;        #gaze_y = (left_y + right_y) / 2&amp;#10;        #Screen in pix conversion&amp;#10;        #gaze_x = (left_x + ((right_x - left_x) / 2)) * win_width&amp;#10;        #gaze_y = (left_y + ((right_y - left_y) / 2)) * win_height&amp;#10;        #Convert to &quot;norm&quot; units of PsychoPy&amp;#10;        #gaze_x = ((left_x + right_x) / 2) * 2 - 1&amp;#10;        #gaze_y = 1 - ((left_y + right_y) / 2) * 2&amp;#10;        #Convert to 'height' units of PyschoPy&amp;#10;        aspect = win.size[0] / win.size[1]&amp;#10;        gaze_x = (((left_x + right_x) / 2) - 0.5) * aspect&amp;#10;        gaze_y = 0.5 - ((left_y + right_y) / 2)&amp;#10;        return (gaze_x, gaze_y)&amp;#10;    elif left_x is not None:&amp;#10;        return (left_x, left_y)&amp;#10;    elif right_x is not None:&amp;#10;        return (right_x, right_y)&amp;#10;    else:&amp;#10;        return None&amp;#10;&amp;#10;&amp;#10;&amp;#10;" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="import * as tr from 'tobii_research';&amp;#10;import {visual} from 'psychopy';&amp;#10;win = new visual.Window({&quot;fullscr&quot;: true});&amp;#10;found_eyetrackers = tr.find_all_eyetrackers();&amp;#10;if ((! found_eyetrackers)) {&amp;#10;    throw new RuntimeError(&quot;No Tobii eye trackers found!&quot;);&amp;#10;}&amp;#10;my_eyetracker = found_eyetrackers[0];&amp;#10;console.log(`Using eye tracker: ${my_eyetracker}`);&amp;#10;gaze_data = [];&amp;#10;latest_gaze = {&quot;left_x&quot;: null, &quot;left_y&quot;: null, &quot;right_x&quot;: null, &quot;right_y&quot;: null};&amp;#10;function gaze_callback(gaze_sample) {&amp;#10;    var timestamp;&amp;#10;    latest_gaze[&quot;left_x&quot;] = gaze_sample[&quot;left_gaze_point_on_display_area&quot;][0];&amp;#10;    latest_gaze[&quot;left_y&quot;] = gaze_sample[&quot;left_gaze_point_on_display_area&quot;][1];&amp;#10;    latest_gaze[&quot;right_x&quot;] = gaze_sample[&quot;right_gaze_point_on_display_area&quot;][0];&amp;#10;    latest_gaze[&quot;right_y&quot;] = gaze_sample[&quot;right_gaze_point_on_display_area&quot;][1];&amp;#10;    timestamp = time.time();&amp;#10;    gaze_data.push({&quot;timestamp&quot;: timestamp, &quot;left_x&quot;: latest_gaze[&quot;left_x&quot;], &quot;left_y&quot;: latest_gaze[&quot;left_y&quot;], &quot;right_x&quot;: latest_gaze[&quot;right_x&quot;], &quot;right_y&quot;: latest_gaze[&quot;right_y&quot;]});&amp;#10;}&amp;#10;function get_current_gaze() {&amp;#10;    /*&amp;#10;    Returns the current gaze position as a tuple (x, y),&amp;#10;    averaged between left and right eyes if both are available.&amp;#10;    Falls back to a single eye if the other is missing.&amp;#10;    Returns None if no gaze data is available.&amp;#10;    */&amp;#10;    var aspect, gaze_x, gaze_y, left_x, left_y, right_x, right_y;&amp;#10;    left_x = latest_gaze[&quot;left_x&quot;];&amp;#10;    left_y = latest_gaze[&quot;left_y&quot;];&amp;#10;    right_x = latest_gaze[&quot;right_x&quot;];&amp;#10;    right_y = latest_gaze[&quot;right_y&quot;];&amp;#10;    if (((left_x !== null) &amp;&amp; (right_x !== null))) {&amp;#10;        aspect = (psychoJS.window.size[0] / psychoJS.window.size[1]);&amp;#10;        gaze_x = ((((left_x + right_x) / 2) - 0.5) * aspect);&amp;#10;        gaze_y = (0.5 - ((left_y + right_y) / 2));&amp;#10;        return [gaze_x, gaze_y];&amp;#10;    } else {&amp;#10;        if ((left_x !== null)) {&amp;#10;            return [left_x, left_y];&amp;#10;        } else {&amp;#10;            if ((right_x !== null)) {&amp;#10;                return [right_x, right_y];&amp;#10;            } else {&amp;#10;                return null;&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="my_eyetracker.subscribe_to(tr.EYETRACKER_GAZE_DATA, gaze_callback, as_dictionary=True)&amp;#10;print('ET started')" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="my_eyetracker.subscribe_to(tr.EYETRACKER_GAZE_DATA, gaze_callback, {&quot;as_dictionary&quot;: true});&amp;#10;console.log(&quot;ET started&quot;);&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="Tobii_SDK_connect" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
